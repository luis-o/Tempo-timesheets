# Tempo API token — generate at: Tempo > Settings > API Integration
TEMPO_API_TOKEN=your-tempo-api-token

# Jira Cloud
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token

# Optional: your Atlassian account ID (auto-resolved if not set)
# JIRA_ACCOUNT_ID=abc123def456

# JQL query to find issues to log time against
# JQL="assignee = currentUser() ORDER BY updated DESC"

# Hours per day (default: 8)
# HOURS_PER_DAY=8
